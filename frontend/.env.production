# ─── WasmOS Frontend — Production Environment ─────────────────────────────────
# When the Next.js build is served as a static export from the Rust backend on
# the SAME origin, leave NEXT_PUBLIC_BACKEND_URL empty ("") so that all fetch()
# calls use relative paths and the Actix-web reverse proxy handles routing.
#
# If the frontend is deployed separately (Vercel, Netlify, etc.) set this to the
# full backend URL, e.g. https://api.yourapp.com
NEXT_PUBLIC_BACKEND_URL=

# WebSocket URL — leave empty to auto-derive from window.location at runtime.
# Set explicitly if the WS endpoint lives on a different host.
# NEXT_PUBLIC_WS_URL=wss://api.yourapp.com/ws
