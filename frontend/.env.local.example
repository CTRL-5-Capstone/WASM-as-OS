# =============================================================================
# WASM-OS Frontend — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# Do NOT commit .env.local to source control.
#
# PRODUCTION BUILD:
#   Leave NEXT_PUBLIC_BACKEND_URL empty (or omit it entirely) when running
#   `npm run build` — the frontend will use relative paths (/v1/...) which
#   resolve to the same origin as the Rust backend serving web/.
#
#   NEXT_PUBLIC_BACKEND_URL="" npm run build
#
# DEVELOPMENT (next dev):
#   Set NEXT_PUBLIC_BACKEND_URL to the Rust backend address so the dev
#   server proxy knows where to forward API calls.
# =============================================================================

# Rust backend base URL (used by next dev proxy and WebSocket URL derivation).
# Leave empty for production static export.
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8080

# Optional: override the WebSocket URL directly (useful if backend is behind
# a reverse proxy that handles WS on a separate path/port).
# NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8080/ws
