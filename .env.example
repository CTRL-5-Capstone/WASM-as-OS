# Server Configuration
WASMOS__SERVER__HOST=127.0.0.1
WASMOS__SERVER__PORT=8080
WASMOS__SERVER__WORKERS=4
WASMOS__SERVER__CORS_ORIGINS=*

# Database Configuration (PostgreSQL only)
WASMOS__DATABASE__URL=postgresql://postgres:postgres@localhost:5432/wasmos

# Security Configuration
WASMOS__SECURITY__AUTH_ENABLED=false
WASMOS__SECURITY__JWT_SECRET=your-secret-key-change-this-in-production
WASMOS__SECURITY__JWT_EXPIRY_HOURS=24
WASMOS__SECURITY__RATE_LIMIT_PER_MINUTE=60

# Resource Limits
WASMOS__LIMITS__MAX_WASM_SIZE_MB=50
WASMOS__LIMITS__MAX_MEMORY_MB=128
WASMOS__LIMITS__EXECUTION_TIMEOUT_SECS=30
WASMOS__LIMITS__MAX_INSTRUCTIONS=10000000
WASMOS__LIMITS__MAX_STACK_DEPTH=1024
WASMOS__LIMITS__MAX_CONCURRENT_TASKS=100

# Logging Configuration
WASMOS__LOGGING__LEVEL=info
WASMOS__LOGGING__FORMAT=json
