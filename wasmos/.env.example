# ─── WasmOS Backend — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control (it contains secrets).
#
# PRODUCTION CHECKLIST:
#   1. Set WASMOS_ENV=production  (triggers hard failure on weak secrets)
#   2. Set strong JWT_SECRET      (min 32 random chars: openssl rand -base64 48)
#   3. Set strong ADMIN_KEY       (openssl rand -hex 32)
#   4. Set AUTH_ENABLED=true
#   5. Set CORS_ORIGINS to your exact frontend domain (not "*")
#   6. Set WASM_FILES_DIR to a persistent volume path
#   7. Use K8s Secrets for sensitive values — do NOT set them in ConfigMaps

# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" to enable strict secret validation at startup.
# The server will refuse to start with weak/default secrets when this is set.
# WASMOS_ENV=production

# ── Server ────────────────────────────────────────────────────────────────────
# Bind address. 0.0.0.0 = all interfaces (required for Docker/K8s).
WASMOS__SERVER__HOST=0.0.0.0
WASMOS__SERVER__PORT=8080
# Number of Actix worker threads (default: num_cpus)
# WASMOS__SERVER__WORKERS=4
# CORS allowed origins. Use specific origins in production, NEVER "*".
# WASMOS__SERVER__CORS_ORIGINS=https://app.yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
# CHANGE: use strong credentials and a non-default database name in production.
WASMOS__DATABASE__URL=postgresql://postgres:postgres@localhost:5432/wasmos

# ── WASM File Storage ─────────────────────────────────────────────────────────
# Path where WASM binaries are stored. Must be writable and persistent.
# In K8s this should match the PVC volumeMount path (e.g. /app/wasm_files).
# WASM_FILES_DIR=/app/wasm_files

# ── Security ──────────────────────────────────────────────────────────────────
# PRODUCTION: set to true — all /v1/* endpoints require a Bearer JWT.
# The server prints a WARNING if this is false when WASMOS_ENV=production.
WASMOS__SECURITY__AUTH_ENABLED=false

# REQUIRED in production (min 32 chars). Generate with:
#   openssl rand -base64 48
WASMOS__SECURITY__JWT_SECRET=change-me-to-a-random-32-char-secret

# JWT token TTL in hours
WASMOS__SECURITY__JWT_EXPIRY_HOURS=24

# Admin key required by POST /v1/auth/token to issue JWTs.
# REQUIRED in production. Generate with: openssl rand -hex 32
WASMOS__SECURITY__ADMIN_KEY=changeme

# Per-IP rate limit (requests per minute)
WASMOS__SECURITY__RATE_LIMIT_PER_MINUTE=120

# ── Redis L2 Cache (optional) ────────────────────────────────────────────────
# When set, responses are cached in Redis across all replicas (L2 cache).
# The app works without Redis — it falls back to moka (L1, in-process) only.
# REDIS_URL=redis://redis:6379

# ── Resource Limits ───────────────────────────────────────────────────────────
# Max WASM file size in MB
WASMOS__LIMITS__MAX_WASM_SIZE_MB=50
# Max memory per execution in MB
WASMOS__LIMITS__MAX_MEMORY_MB=128
# Execution timeout in seconds
WASMOS__LIMITS__EXECUTION_TIMEOUT_SECS=30
# Max concurrent tasks
WASMOS__LIMITS__MAX_CONCURRENT_TASKS=16

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error
WASMOS__LOGGING__LEVEL=info
# Log format: json (production) | pretty (development)
WASMOS__LOGGING__FORMAT=json
